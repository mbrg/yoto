{
  "meta": {
    "name": "yoto",
    "version": "1.0.0",
    "description": "Claude Code with yoto"
  },
  "security": {
    "groups": [
      "claude_code_macos",
      "claude_code_linux",
      "vscode_macos",
      "unlink_protection"
    ],
    "signal_mode": "isolated",
    "capability_elevation": false
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.claude"
    ],
    "read": [
      "$HOME/.local/share/claude",
      "$HOME/.ssh",
      "$HOME/.config/op",
      "$HOME/.config/gh",
      "$HOME/Library/Group Containers/2BUA8C4S2C.com.1password"
    ],
    "allow_file": [
      "$HOME/.claude.json",
      "$HOME/.claude.json.lock"
    ],
    "read_file": [
      "$HOME/.gitconfig",
      "$HOME/.gitignore_global",
      "$HOME/.config/git/ignore"
    ]
  },
  "network": {
    "block": false,
    "network_profile": "minimal",
    "proxy_allow": [
      "github.com",
      "api.github.com",
      "codeload.github.com",
      "raw.githubusercontent.com",
      "objects.githubusercontent.com",

      "rekor.sigstore.dev",
      "fulcio.sigstore.dev",
      "tuf-repo-cdn.sigstore.dev",
      "oauth2.sigstore.dev",

      "docs.anthropic.com",

      "yoto.dev",
      "yotoplay.com"
    ]
  },
  "workdir": {
    "access": "readwrite"
  },
  "hooks": {
    "claude-code": {
      "event": "PostToolUseFailure",
      "matcher": "Read|Write|Edit|Bash",
      "script": "nono-hook.sh"
    }
  },
  "undo": {
    "exclude_patterns": ["node_modules", ".next", "__pycache__", "target"],
    "exclude_globs": ["*.tmp.[0-9]*.[0-9]*"]
  },
  "interactive": true
}
